# Reset to Xcode's native toolchain for macOS app development
# nix-darwin sets DEVELOPER_DIR/SDKROOT/NIX_* to nix SDK which breaks xcodebuild + cmake
export DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
export SDKROOT="$DEVELOPER_DIR/Platforms/MacOSX.platform/Developer/SDKs/MacOSX.sdk"
export CC="$(xcrun --find clang)"
export CXX="$(xcrun --find clang++)"
unset NIX_CFLAGS_COMPILE NIX_LDFLAGS NIX_APPLE_SDK_VERSION
unset NIX_CFLAGS_COMPILE_FOR_BUILD NIX_LDFLAGS_FOR_BUILD

# Xcode + Homebrew toolchain first, nix tools still available for git/gh/etc
PATH_add "$DEVELOPER_DIR/Toolchains/XcodeDefault.xctoolchain/usr/bin"
PATH_add "$DEVELOPER_DIR/usr/bin"
PATH_add "/opt/homebrew/bin"
